<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>フィッシャーの分離定理</title>
<style>
  :root{
    --bg:#ffffff; --ink:#33403a; --grid:#33403a22;
    --ppf:#d97757; --cml:#4c8bf5; --ic:#34a853; --dotP:#f4b400; --dotC:#a142f4;
  }
  *{box-sizing:border-box;}
  body{
    margin:0; padding:20px; background:var(--bg); color:var(--ink);
    font-family:"Hiragino Sans","Yu Gothic",system-ui,sans-serif;
    display:flex; flex-direction:column; align-items:center; gap:14px;
  }
  h3{margin:0; font-size:17px; font-weight:600;}
  #viz{width:100%; max-width:720px;}
  svg{width:100%; height:auto; display:block;}
  .controls{width:100%; max-width:720px; display:flex; flex-direction:column; gap:14px;}
  .row{display:flex; align-items:center; gap:12px;}
  .row label{flex:0 0 210px; font-size:13px;}
  .row input[type=range]{flex:1;}
  .row .val{flex:0 0 46px; text-align:right; font-size:13px; font-variant-numeric:tabular-nums;}
  .hud{display:flex; gap:24px; font-size:13px;}
  .hud b{font-variant-numeric:tabular-nums;}
</style>
</head>
<body>

<h3>フィッシャーの分離定理</h3>

<div id="viz">
  <svg viewBox="0 0 700 350" xmlns="http://www.w3.org/2000/svg">
    <g id="gridX"></g>
    <g id="gridY"></g>
    <line id="axisX" stroke="var(--ink)" stroke-opacity="0.4"/>
    <line id="axisY" stroke="var(--ink)" stroke-opacity="0.4"/>
    <path id="ppf" fill="none" stroke="var(--ppf)" stroke-width="3" stroke-dasharray="4,3"/>
    <text id="ppfLabel" fill="var(--ppf)" font-size="12"></text>
    <line id="cml" stroke="var(--cml)" stroke-width="2"/>
    <text id="cmlLabel" fill="var(--cml)" font-size="12" text-anchor="end"></text>
    <path id="ic" fill="none" stroke="var(--ic)" stroke-width="2"/>
    <text id="icLabel" fill="var(--ic)" font-size="12"></text>
    <circle id="dotP" r="6" fill="var(--dotP)" stroke="#fff" stroke-width="2"/>
    <text id="dotPLabel" fill="var(--dotP)" font-size="12" font-weight="bold"></text>
    <circle id="dotC" r="6" fill="var(--dotC)" stroke="#fff" stroke-width="2"/>
    <text id="dotCLabel" fill="var(--dotC)" font-size="12" font-weight="bold"></text>
    <text id="xLabel" fill="var(--ink)" font-size="12" text-anchor="end"></text>
    <text id="yLabel" fill="var(--ink)" font-size="12" transform="rotate(-90)"></text>
  </svg>
</div>

<div class="controls">
  <div class="row">
    <label for="r">市場利子率 (r)</label>
    <input type="range" id="r" min="0" max="1" step="0.05" value="0.2">
    <span class="val" id="rVal">0.20</span>
  </div>
  <div class="row">
    <label for="beta">時間選好 (現在志向 ↔ 将来志向)</label>
    <input type="range" id="beta" min="0.5" max="2" step="0.1" value="1.0">
    <span class="val" id="betaVal">1.0</span>
  </div>
  <div class="hud">
    <div>最適生産点 (C0): <b id="hudP">-</b></div>
    <div>最適消費点 (C0): <b id="hudC">-</b></div>
  </div>
</div>

<script>
// ---- plot area (SVG coords) ----
const M = {l:60, r:20, t:20, b:40};
const W = 700, H = 350;
const plotW = W - M.l - M.r, plotH = H - M.t - M.b;
const domain = [0, 260];

function sx(c0){ return M.l + (c0 - domain[0]) / (domain[1]-domain[0]) * plotW; }
function sy(c1){ return M.t + plotH - (c1 - domain[0]) / (domain[1]-domain[0]) * plotH; }

function pathFromPoints(pts){
  return pts.map((p,i) => (i===0?'M':'L') + sx(p.c0).toFixed(2) + ',' + sy(p.c1).toFixed(2)).join('');
}

// static PPF
const ppfPoints = [];
for (let c0 = 0; c0 <= 190; c0 += 2){
  const c1 = 200 - 0.004*c0*c0;
  if (c1 >= 0) ppfPoints.push({c0, c1});
}

// grid + axes (static)
const gridX = document.getElementById('gridX');
const gridY = document.getElementById('gridY');
for (let v=0; v<=250; v+=50){
  const lx = document.createElementNS('http://www.w3.org/2000/svg','line');
  lx.setAttribute('x1', sx(v)); lx.setAttribute('x2', sx(v));
  lx.setAttribute('y1', sy(0)); lx.setAttribute('y2', sy(260));
  lx.setAttribute('stroke','var(--grid)');
  gridX.appendChild(lx);

  const ly = document.createElementNS('http://www.w3.org/2000/svg','line');
  ly.setAttribute('y1', sy(v)); ly.setAttribute('y2', sy(v));
  ly.setAttribute('x1', sx(0)); ly.setAttribute('x2', sx(260));
  ly.setAttribute('stroke','var(--grid)');
  gridY.appendChild(ly);

  const tx = document.createElementNS('http://www.w3.org/2000/svg','text');
  tx.setAttribute('x', sx(v)); tx.setAttribute('y', sy(0)+16);
  tx.setAttribute('font-size','10'); tx.setAttribute('text-anchor','middle');
  tx.setAttribute('fill','var(--ink)'); tx.textContent = v;
  gridX.appendChild(tx);

  const ty = document.createElementNS('http://www.w3.org/2000/svg','text');
  ty.setAttribute('x', sx(0)-8); ty.setAttribute('y', sy(v)+3);
  ty.setAttribute('font-size','10'); ty.setAttribute('text-anchor','end');
  ty.setAttribute('fill','var(--ink)'); ty.textContent = v;
  gridY.appendChild(ty);
}
document.getElementById('axisX').setAttribute('x1', sx(0));
document.getElementById('axisX').setAttribute('x2', sx(260));
document.getElementById('axisX').setAttribute('y1', sy(0));
document.getElementById('axisX').setAttribute('y2', sy(0));
document.getElementById('axisY').setAttribute('y1', sy(0));
document.getElementById('axisY').setAttribute('y2', sy(260));
document.getElementById('axisY').setAttribute('x1', sx(0));
document.getElementById('axisY').setAttribute('x2', sx(0));

document.getElementById('xLabel').setAttribute('x', sx(260));
document.getElementById('xLabel').setAttribute('y', sy(0)+34);
document.getElementById('xLabel').textContent = '現在志向の消費・富 (C0) →';

const yLabelEl = document.getElementById('yLabel');
yLabelEl.setAttribute('x', -(sy(0)-14));
yLabelEl.setAttribute('y', 16);
yLabelEl.textContent = '将来志向の消費・富 (C1) ↑';

document.getElementById('ppf').setAttribute('d', pathFromPoints(ppfPoints));
const ppfLabel = document.getElementById('ppfLabel');
ppfLabel.setAttribute('x', sx(50)); ppfLabel.setAttribute('y', sy(175));
ppfLabel.textContent = '生産可能フロンティア (PPF)';

function render(){
  const r = parseFloat(document.getElementById('r').value);
  const beta = parseFloat(document.getElementById('beta').value);
  document.getElementById('rVal').textContent = r.toFixed(2);
  document.getElementById('betaVal').textContent = beta.toFixed(1);

  const C0_p = Math.min(185, (1+r)/0.008);
  const C1_p = Math.max(10, 200 - 0.004*C0_p*C0_p);
  const Wealth = C0_p + C1_p/(1+r);
  const alpha = beta/(1+beta);
  const C0_c = alpha * Wealth;
  const C1_c = (1-alpha) * Wealth * (1+r);

  // CML
  const cml = document.getElementById('cml');
  cml.setAttribute('x1', sx(0)); cml.setAttribute('y1', sy(Wealth*(1+r)));
  cml.setAttribute('x2', sx(Wealth)); cml.setAttribute('y2', sy(0));
  const cmlLabel = document.getElementById('cmlLabel');
  cmlLabel.setAttribute('x', sx(Wealth-15)); cmlLabel.setAttribute('y', sy(25));
  cmlLabel.textContent = '資本市場線 (CML, 傾き: -(1+r))';

  // Indifference curve
  const utilityConstant = Math.pow(C0_c, alpha) * Math.pow(C1_c, 1-alpha);
  const icPoints = [];
  const startC0 = Math.max(20, C0_c-60);
  const endC0 = Math.min(240, C0_c+85);
  for (let c0=startC0; c0<=endC0; c0+=2){
    const c1 = Math.pow(utilityConstant/Math.pow(c0, alpha), 1/(1-alpha));
    if (c1>=0 && c1<=300) icPoints.push({c0, c1});
  }
  document.getElementById('ic').setAttribute('d', pathFromPoints(icPoints));
  const icLabel = document.getElementById('icLabel');
  icLabel.setAttribute('x', sx(C0_c+15)); icLabel.setAttribute('y', sy(C1_c+25));
  icLabel.textContent = '無差別曲線';

  // points
  const dotP = document.getElementById('dotP');
  dotP.setAttribute('cx', sx(C0_p)); dotP.setAttribute('cy', sy(C1_p));
  const dotPLabel = document.getElementById('dotPLabel');
  dotPLabel.setAttribute('x', sx(C0_p+8)); dotPLabel.setAttribute('y', sy(C1_p+12));
  dotPLabel.textContent = '最適生産点 (企業の投資決定)';

  const dotC = document.getElementById('dotC');
  dotC.setAttribute('cx', sx(C0_c)); dotC.setAttribute('cy', sy(C1_c));
  const dotCLabel = document.getElementById('dotCLabel');
  dotCLabel.setAttribute('x', sx(C0_c+8)); dotCLabel.setAttribute('y', sy(C1_c-12));
  dotCLabel.textContent = '最適消費点 (個人の消費決定)';

  document.getElementById('hudP').textContent = C0_p.toFixed(1);
  document.getElementById('hudC').textContent = C0_c.toFixed(1);
}

document.getElementById('r').addEventListener('input', render);
document.getElementById('beta').addEventListener('input', render);
render();
</script>
</body>
</html>
